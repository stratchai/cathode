{
  "name": "@stratchai/cathode",
  "version": "0.1.0",
  "description": "A retro CRT curved-screen datagrid for the web",
  "type": "module",
  "main": "dist/cathode.umd.cjs",
  "module": "dist/cathode.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/cathode.js",
      "require": "./dist/cathode.umd.cjs"
    },
    "./style": "./dist/cathode.css"
  },
  "files": ["dist"],
  "scripts": {
    "dev":       "vite",
    "build":     "vite build --config vite.lib.config.ts",
    "build:demo":"vite build",
    "preview":   "vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript":        "^5.7.2",
    "vite":              "^5.4.14",
    "vue":               "^3.5.13",
    "vue-tsc":           "^2.2.0"
  }
}
