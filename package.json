{
  "name": "@stratchai/cathode",
  "version": "0.1.5",
  "description": "A retro CRT curved-screen datagrid for the web",
  "license": "MIT",
  "author": "stratchai",
  "repository": {
    "type": "git",
    "url": "https://github.com/stratchai/cathode.git"
  },
  "bugs": {
    "url": "https://github.com/stratchai/cathode/issues"
  },
  "homepage": "https://github.com/stratchai/cathode#readme",
  "keywords": [
    "datagrid",
    "vue",
    "vue3",
    "crt",
    "retro",
    "phosphor",
    "trading-ui",
    "dashboard",
    "stratchai"
  ],
  "type": "module",
  "main": "dist/cathode.umd.cjs",
  "module": "dist/cathode.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/cathode.js",
      "require": "./dist/cathode.umd.cjs"
    },
    "./style": "./dist/cathode.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.ts && vue-tsc -p tsconfig.lib.json",
    "build:demo": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "PWDEBUG=1 playwright test",
    "capture:hero": "bash tools/capture-hero.sh"
  },
  "peerDependencies": {
    "three": "^0.170.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "three": "^0.170.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.14",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  }
}